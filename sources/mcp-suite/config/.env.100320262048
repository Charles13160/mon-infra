# /srv/mcp-suite/config/.env
# chmod 600 — ne jamais committer

# PostgreSQL (base license dans mcp-postgres Docker pour l'instant)
MCP_DATABASE_URL=postgresql://master:$(cat /run/secrets/postgres_password)@mcp-postgres:5432/license?sslmode=disable

# JWT admin — généré aléatoirement
MCP_JWT_ADMIN_SECRET=CHANGE_ME
